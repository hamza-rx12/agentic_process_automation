# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Email (protonmail or imap)
MAIL_BACKEND=protonmail
EMAIL=you@example.com
APP_PASSWORD=your-app-password
IMAP_HOST=127.0.0.1
IMAP_PORT=1143

# Browser
BROWSER_HEADLESS=false
BROWSER_VIEWPORT=1280x720
BROWSER_EXECUTABLE=/usr/bin/chromium

# Agent limits
MAX_TURNS=50
MAX_BUDGET_USD=5.0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost/
RABBITMQ_QUEUE=email_tasks

# A2A
BROWSER_AGENT_URL=http://localhost:8080
A2A_PORT=8080
