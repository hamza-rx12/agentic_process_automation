# --- Anthropic / Claude Agent SDK ---
# This is forwarded as ANTHROPIC_AUTH_TOKEN to the Claude Agent SDK.
AIPLATFORM_API_KEY=sk-ant-...
# Leave AIPLATFORM_BASE_URL unset to talk directly to api.anthropic.com.
# AIPLATFORM_BASE_URL=

# --- Model ---
MODEL=claude-haiku-4-5
MODEL_TEMPERATURE=0.2
MODEL_MAX_TOKENS=4096

# --- Email (protonmail or imap) ---
MAIL_BACKEND=protonmail
EMAIL=you@example.com
APP_PASSWORD=your-app-password
IMAP_HOST=127.0.0.1
IMAP_PORT=1143

# --- Browser ---
BROWSER_HEADLESS=true
BROWSER_VIEWPORT=1280x720
# BROWSER_EXECUTABLE is set automatically inside the browser-agent container.

# --- Agent limits ---
AGENT_MAX_TURNS=50
AGENT_PERMISSION_MODE=bypassPermissions
AGENT_DISALLOWED_TOOLS=WebSearch,WebFetch,Read,Write,Edit,Bash,Glob,Grep,Agent

# --- RabbitMQ ---
RABBITMQ_URL=amqp://guest:guest@localhost/
RABBITMQ_QUEUE=email_tasks
